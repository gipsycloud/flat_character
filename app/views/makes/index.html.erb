<%= render "template/nav" %>

<section class="min-h-screen bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 py-24 sm:py-32 relative overflow-hidden">
  <!-- Background decorative elements -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-emerald-500/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="px-6 mx-auto max-w-6xl lg:px-8 relative z-10">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center mb-16 lg:mb-20">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm mb-6">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        <span class="text-xs font-medium text-slate-300 tracking-wide uppercase">Available Now</span>
      </div>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-medium tracking-tight text-white leading-none mb-6">
        Finding A Roommate<br>
        <span class="text-emerald-400">Made Easier</span>
      </h2>
      <p class="text-lg text-slate-400 leading-relaxed max-w-xl mx-auto">
        Connect with like-minded people. We match you based on lifestyle, habits, and preferences — not just budget.
      </p>
    </div>

    <!-- Filter tabs (decorative but adds visual interest) -->
    <div class="flex items-center justify-center gap-2 mb-12 flex-wrap">
      <button class="px-4 py-2 rounded-full text-sm font-medium bg-white text-black shadow-[0_0_15px_rgba(255,255,255,0.1)] transition-all duration-300">All</button>
      <button class="px-4 py-2 rounded-full text-sm font-medium text-slate-400 border border-white/10 hover:border-white/20 hover:text-white transition-all duration-300">Professionals</button>
      <button class="px-4 py-2 rounded-full text-sm font-medium text-slate-400 border border-white/10 hover:border-white/20 hover:text-white transition-all duration-300">Students</button>
      <button class="px-4 py-2 rounded-full text-sm font-medium text-slate-400 border border-white/10 hover:border-white/20 hover:text-white transition-all duration-300">Creatives</button>
    </div>

    <!-- Cards Grid -->
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <% @user.each do |u| %>
        <div class="group relative bg-[rgba(24,24,27,0.3)] rounded-2xl border border-white/10 overflow-hidden transition-all duration-500 hover:border-white/20 hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(0,0,0,0.5)]">
          <!-- Top gradient line -->
          <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <!-- Avatar Section -->
          <div class="relative h-56 overflow-hidden">
            <a href="#" class="block h-full">
              <%= cl_image_tag(u.avatar_url, width: 400, height: 300, :crop=>"fill", class: "w-full h-full object-cover transition-transform duration-700 group-hover:scale-105") %>
            </a>
            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-[rgba(24,24,27,0.9)] via-transparent to-transparent"></div>
            <!-- Status badge -->
            <div class="absolute top-3 right-3 flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-black/50 backdrop-blur-sm border border-white/10">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
              <span class="text-[11px] font-medium text-slate-300">Active</span>
            </div>
            <!-- Name overlay -->
            <div class="absolute bottom-3 left-4 right-4">
              <h3 class="text-lg font-medium text-white tracking-tight truncate">
                <a href="#" class="hover:text-emerald-400 transition-colors duration-300"><%= u.user_name %></a>
              </h3>
              <p class="text-sm text-slate-400 mt-0.5"><%= u.user_info.job_type %></p>
            </div>
          </div>

          <!-- Content -->
          <div class="p-5 pt-3">
            <p class="text-sm text-slate-400 leading-relaxed line-clamp-3 mb-5">
              <%= u.user_info.description %>
            </p>

            <!-- Social links -->
            <div class="flex items-center gap-2 pt-4 border-t border-white/5">
              <% if u.user_info.facebook_link.present? %>
                <a href="<%= u.user_info.facebook_link %>" target="_blank" class="flex items-center justify-center w-9 h-9 rounded-lg border border-white/10 text-slate-500 hover:text-white hover:border-white/20 hover:bg-white/5 transition-all duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 71 72" fill="currentColor">
                    <path d="M46.4233 38.6403L47.7279 30.3588H39.6917V24.9759C39.6917 22.7114 40.8137 20.4987 44.4013 20.4987H48.1063V13.4465C45.9486 13.1028 43.7685 12.9168 41.5834 12.8901C34.9692 12.8901 30.651 16.8626 30.651 24.0442V30.3588H23.3193V38.6403H30.651V58.671H39.6917V38.6403H46.4233Z"/>
                  </svg>
                </a>
              <% end %>
              <% if u.user_info.twitter.present? %>
                <a href="<%= u.user_info.twitter %>" target="_blank" class="flex items-center justify-center w-9 h-9 rounded-lg border border-white/10 text-slate-500 hover:text-white hover:border-white/20 hover:bg-white/5 transition-all duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 71 72" fill="currentColor">
                    <path d="M40.7568 32.1716L59.3704 11H54.9596L38.7974 29.383L25.8887 11H11L30.5205 38.7983L11 61H15.4111L32.4788 41.5869L46.1113 61H61L40.7557 32.1716H40.7568ZM34.7152 39.0433L32.7374 36.2752L17.0005 14.2492H23.7756L36.4755 32.0249L38.4533 34.7929L54.9617 57.8986H48.1865L34.7152 39.0443V39.0433Z"/>
                  </svg>
                </a>
              <% end %>
              <% if u.user_info.linkedin.present? %>
                <a href="<%= u.user_info.linkedin %>" target="_blank" class="flex items-center justify-center w-9 h-9 rounded-lg border border-white/10 text-slate-500 hover:text-white hover:border-white/20 hover:bg-white/5 transition-all duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 71 72" fill="currentColor">
                    <path d="M24.7612 55.999V28.3354H15.5433V55.999H24.7621H24.7612ZM20.1542 24.5591C23.3679 24.5591 25.3687 22.4348 25.3687 19.7801C25.3086 17.065 23.3679 15 20.2153 15C17.0605 15 15 17.065 15 19.7799C15 22.4346 17.0001 24.5588 20.0938 24.5588H20.1534L20.1542 24.5591ZM29.8633 55.999H39.0805V40.5521C39.0805 39.7264 39.1406 38.8985 39.3841 38.3088C40.0502 36.6562 41.5668 34.9455 44.1138 34.9455C47.4484 34.9455 48.7831 37.4821 48.7831 41.2014V55.999H58V40.1376C58 31.6408 53.4532 27.6869 47.3887 27.6869C42.4167 27.6869 40.233 30.4589 39.0198 32.347H39.0812V28.3364H29.8638C29.9841 30.9316 29.8631 56 29.8631 56L29.8633 55.999Z"/>
                  </svg>
                </a>
              <% end %>
              <% if u.user_info.instagram.present? %>
                <a href="<%= u.user_info.instagram %>" target="_blank" class="flex items-center justify-center w-9 h-9 rounded-lg border border-white/10 text-slate-500 hover:text-white hover:border-white/20 hover:bg-white/5 transition-all duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 71 72" fill="currentColor">
                    <path d="M27.3762 35.7808C27.3762 31.1786 31.1083 27.4468 35.7132 27.4468C40.3182 27.4468 44.0522 31.1786 44.0522 35.7808C44.0522 40.383 40.3182 44.1148 35.7132 44.1148C31.1083 44.1148 27.3762 40.383 27.3762 35.7808ZM22.8683 35.7808C22.8683 42.8708 28.619 48.618 35.7132 48.618C42.8075 48.618 48.5581 42.8708 48.5581 35.7808C48.5581 28.6908 42.8075 22.9436 35.7132 22.9436C28.619 22.9436 22.8683 28.6908 22.8683 35.7808ZM46.0648 22.4346C46.0646 23.0279 46.2404 23.608 46.5701 24.1015C46.8997 24.595 47.3684 24.9797 47.9168 25.2069C48.4652 25.4342 49.0688 25.4939 49.6511 25.3784C50.2334 25.2628 50.7684 24.9773 51.1884 24.5579C51.6084 24.1385 51.8945 23.6041 52.0105 23.0222C52.1266 22.4403 52.0674 21.8371 51.8404 21.2888C51.6134 20.7406 51.2289 20.2719 50.7354 19.942C50.2418 19.6122 49.6615 19.436 49.0679 19.4358H49.0667C48.2708 19.4361 47.5077 19.7522 46.9449 20.3144C46.3821 20.8767 46.0655 21.6392 46.0648 22.4346ZM25.6072 56.1302C23.1683 56.0192 21.8427 55.6132 20.9618 55.2702C19.7939 54.8158 18.9606 54.2746 18.0845 53.4002C17.2083 52.5258 16.666 51.6938 16.2133 50.5266C15.8699 49.6466 15.4637 48.3214 15.3528 45.884C15.2316 43.2488 15.2073 42.4572 15.2073 35.781C15.2073 29.1048 15.2336 28.3154 15.3528 25.678C15.4639 23.2406 15.8731 21.918 16.2133 21.0354C16.668 19.8682 17.2095 19.0354 18.0845 18.1598C18.9594 17.2842 19.7919 16.7422 20.9618 16.2898C21.8423 15.9466 23.1683 15.5406 25.6072 15.4298C28.244 15.3086 29.036 15.2844 35.7132 15.2844C42.3904 15.2844 43.1833 15.3106 45.8223 15.4298C48.2612 15.5408 49.5846 15.9498 50.4677 16.2898C51.6356 16.7422 52.4689 17.2854 53.345 18.1598C54.2211 19.0342 54.7615 19.8682 55.2161 21.0354C55.5595 21.9154 55.9658 23.2406 56.0767 25.678C56.1979 28.3154 56.2221 29.1048 56.2221 35.781C56.2221 42.4572 56.1979 43.2466 56.0767 45.884C55.9656 48.3214 55.5573 49.6462 55.2161 50.5266C54.7615 51.6938 54.2199 52.5266 53.345 53.4002C52.4701 54.2738 51.6356 54.8158 50.4677 55.2702C49.5872 55.6134 48.2612 56.0194 45.8223 56.1302C43.1855 56.2514 42.3934 56.2756 35.7132 56.2756C29.033 56.2756 28.2432 56.2514 25.6072 56.1302ZM25.4001 10.9322C22.7371 11.0534 20.9174 11.4754 19.3282 12.0934C17.6824 12.7316 16.2892 13.5878 14.897 14.977C13.5047 16.3662 12.6502 17.7608 12.0116 19.4056C11.3933 20.9948 10.971 22.8124 10.8497 25.4738C10.7265 28.1394 10.6982 28.9916 10.6982 35.7808C10.6982 42.57 10.7265 43.4222 10.8497 46.0878C10.971 48.7494 11.3933 50.5668 12.0116 52.156C12.6502 53.7998 13.5049 55.196 14.897 56.5846C16.289 57.9732 17.6824 58.8282 19.3282 59.4682C20.9204 60.0862 22.7371 60.5082 25.4001 60.6294C28.0687 60.7506 28.92 60.7808 35.7132 60.7808C42.5065 60.7808 43.3592 60.7526 46.0264 60.6294C48.6896 60.5082 50.5081 60.0862 52.0983 59.4682C53.7431 58.8282 55.1373 57.9738 56.5295 56.5846C57.9218 55.1954 58.7745 53.7998 59.4149 52.156C60.0332 50.5668 60.4575 48.7492 60.5768 46.0878C60.698 43.4202 60.7262 42.57 60.7262 35.7808C60.7262 28.9916 60.698 28.1394 60.5768 25.4738C60.4555 22.8122 60.0332 20.9938 59.4149 19.4056C58.7745 17.7618 57.9196 16.3684 56.5295 14.977C55.1395 13.5856 53.7431 12.7316 52.1003 12.0934C50.5081 11.4754 48.6894 11.0514 46.0284 10.9322C43.3612 10.811 42.5085 10.7808 35.7152 10.7808C28.922 10.7808 28.0687 10.809 25.4001 10.9322Z"/>
                  </svg>
                </a>
              <% end %>

              <!-- Spacer -->
              <div class="flex-1"></div>

              <!-- View profile button -->
              <a href="#" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-white text-black text-sm font-medium hover:shadow-[0_0_20px_rgba(255,255,255,0.15)] transition-all duration-300">
                View
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform duration-300">
                  <path d="M5 12h14"/>
                  <path d="m12 5 7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Empty state (conditional) -->
    <% if @user.empty? %>
      <div class="text-center py-20">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-white/5 border border-white/10 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <line x1="19" x2="19" y1="8" y2="14"/>
            <line x1="22" x2="16" y1="11" y2="11"/>
          </svg>
        </div>
        <h3 class="text-xl font-medium text-white mb-2">No roommates found</h3>
        <p class="text-slate-400 text-sm max-w-sm mx-auto">Check back soon — new people are joining every day looking for their perfect match.</p>
      </div>
    <% end %>
  </div>
</section>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>