<div class="space-y-6">
  <header class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-indigo-600">Admin dashboard</p>
        <h1 class="mt-2 text-3xl font-semibold text-slate-900">Overview</h1>
        <p class="mt-2 text-sm text-slate-500">Manage users, members, and subscriptions with a quick overview of current activity.</p>
      </div>
      <div class="inline-flex items-center gap-2 rounded-full border border-indigo-100 bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700">
        <span class="h-2.5 w-2.5 rounded-full bg-indigo-600"></span>
        Live analytics
      </div>
    </div>
  </header>

  <section class="grid gap-4 xl:grid-cols-3">
    <article class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Users</p>
          <p class="mt-4 text-4xl font-semibold text-slate-900"><%= User.count %></p>
        </div>
        <div class="rounded-2xl bg-indigo-100 p-3 text-indigo-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5V8H2v12h5m10 0v-8H7v8m10 0h5" />
          </svg>
        </div>
      </div>
      <p class="mt-5 text-sm text-slate-500">Total registered users across the platform.</p>
    </article>

    <article class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Members</p>
          <p class="mt-4 text-4xl font-semibold text-slate-900"><%= Member.count %></p>
        </div>
        <div class="rounded-2xl bg-emerald-100 p-3 text-emerald-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7a4 4 0 018 0v1h1a2 2 0 012 2v1a2 2 0 01-2 2h-1v2a2 2 0 01-2 2H9a2 2 0 01-2-2v-2H6a2 2 0 01-2-2V10a2 2 0 012-2h1V7z" />
          </svg>
        </div>
      </div>
      <p class="mt-5 text-sm text-slate-500">Active members with full profile details enrolled.</p>
    </article>

    <article class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Subscribers</p>
          <p class="mt-4 text-4xl font-semibold text-slate-900"><%= Subscription.count %></p>
        </div>
        <div class="rounded-2xl bg-sky-100 p-3 text-sky-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
          </svg>
        </div>
      </div>
      <p class="mt-5 text-sm text-slate-500">Newsletter and updates subscribers list.</p>
    </article>
  </section>

  <section class="grid gap-6 xl:grid-cols-2">
    <article class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold text-slate-900">Recent subscribers</h2>
          <p class="mt-1 text-sm text-slate-500">Latest email signups in the last 30 days.</p>
        </div>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-700"><%= @subscribe.size %> records</span>
      </div>
      <div class="mt-6 overflow-hidden rounded-3xl border border-gray-100">
        <%= render partial: 'members/subscribe' %>
      </div>
    </article>

    <article class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold text-slate-900">Member directory</h2>
          <p class="mt-1 text-sm text-slate-500">Active members with recent activity and contact details.</p>
        </div>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-700"><%= @members.size %> members</span>
      </div>
      <div class="mt-6 overflow-hidden rounded-3xl border border-gray-100">
        <%= render partial: 'members/member' %>
      </div>
    </article>
  </section>
</div>
