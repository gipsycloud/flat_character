<div class="space-y-6">
  <% if notice.present? %>
    <p class="inline-block rounded-2xl bg-emerald-50 px-4 py-2 text-sm font-medium text-emerald-700" id="notice"><%= notice %></p>
  <% end %>

  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-semibold text-slate-900">Members</h1>
        <p class="mt-1 text-sm text-slate-500">View members, users, and subscription activity in one place.</p>
      </div>
      <%= link_to "New Member", new_member_path, class: "inline-flex items-center justify-center rounded-full bg-blue-700 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-3">
      <article class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Users</p>
        <p class="mt-4 text-3xl font-semibold text-slate-900"><%= User.count %></p>
        <p class="mt-3 text-sm text-slate-500">Total registered user accounts.</p>
      </article>
      <article class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Members</p>
        <p class="mt-4 text-3xl font-semibold text-slate-900"><%= Member.count %></p>
        <p class="mt-3 text-sm text-slate-500">Active member profiles on the platform.</p>
      </article>
      <article class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Subscribers</p>
        <p class="mt-4 text-3xl font-semibold text-slate-900"><%= Subscription.count %></p>
        <p class="mt-3 text-sm text-slate-500">Newsletter and update subscribers.</p>
      </article>
    </div>
  </div>

  <div class="grid gap-6 xl:grid-cols-2">
    <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold text-slate-900">Subscribers</h2>
          <p class="mt-1 text-sm text-slate-500">Recent email subscriptions.</p>
        </div>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-700"><%= @subscribe.size %> records</span>
      </div>
      <div class="mt-6 overflow-hidden rounded-3xl border border-slate-100">
        <%= render 'subscribe' %>
      </div>
    </section>

    <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold text-slate-900">Members</h2>
          <p class="mt-1 text-sm text-slate-500">Member directory and management.</p>
        </div>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-700"><%= @members.size %> members</span>
      </div>
      <div class="mt-6 overflow-hidden rounded-3xl border border-slate-100">
        <%= render @members %>
      </div>
    </section>
  </div>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex items-center justify-between gap-4">
      <div>
        <h2 class="text-lg font-semibold text-slate-900">Users</h2>
        <p class="mt-1 text-sm text-slate-500">User accounts and roles.</p>
      </div>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-700"><%= @users.size %> users</span>
    </div>
    <div class="mt-6 overflow-hidden rounded-3xl border border-slate-100">
      <%= render 'user' %>
    </div>
  </section>
</div>