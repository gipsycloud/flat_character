<div class="relative overflow-x-auto bg-white">
  <table class="min-w-full divide-y divide-slate-200 text-sm text-left text-slate-600">
    <thead class="bg-slate-50 text-xs uppercase tracking-[0.2em] text-slate-500">
      <tr>
        <th scope="col" class="px-5 py-3">Member name</th>
        <th scope="col" class="px-5 py-3">Email</th>
        <th scope="col" class="px-5 py-3">Phone</th>
        <th scope="col" class="px-5 py-3">Address</th>
        <th scope="col" class="px-5 py-3">Joined</th>
        <th scope="col" class="px-5 py-3">Last login</th>
        <th scope="col" class="px-5 py-3">Type</th>
        <th scope="col" class="px-5 py-3">Action</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100 bg-white">
      <% @members.each do |member| %>
        <tr class="hover:bg-slate-50">
          <th scope="row" class="whitespace-nowrap px-5 py-4 font-medium text-slate-900"><%= member.memberName %></th>
          <td class="px-5 py-4 text-slate-500"><%= member.email %></td>
          <td class="px-5 py-4 text-slate-500"><%= member.phoneNumber %></td>
          <td class="px-5 py-4 text-slate-500"><%= member.memberAddress %></td>
          <td class="px-5 py-4 text-slate-500"><%= member.joinDate.to_time.strftime('%B %e, %Y') %></td>
          <td class="px-5 py-4 text-slate-500"><%= member.lastLogin %></td>
          <td class="px-5 py-4 text-slate-500"><%= member.memberType %></td>
          <td class="px-5 py-4 space-x-2">
            <%= link_to "Show", member, class: "inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-200" %>
            <%= link_to "Edit", edit_member_path(member), class: "inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-200" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
