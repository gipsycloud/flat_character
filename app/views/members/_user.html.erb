<div class="relative overflow-x-auto bg-white">
  <table class="min-w-full divide-y divide-slate-200 text-sm text-left text-slate-600">
    <thead class="bg-slate-50 text-xs uppercase tracking-[0.2em] text-slate-500">
      <tr>
        <th scope="col" class="px-5 py-3">User name</th>
        <th scope="col" class="px-5 py-3">Email</th>
        <th scope="col" class="px-5 py-3">Phone</th>
        <th scope="col" class="px-5 py-3">Address</th>
        <th scope="col" class="px-5 py-3">Role</th>
        <th scope="col" class="px-5 py-3">Action</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100 bg-white">
      <% @users.each do |user| %>
        <tr class="hover:bg-slate-50">
          <th scope="row" class="whitespace-nowrap px-5 py-4 font-medium text-slate-900"><%= user.id %> | <%= user.user_name %></th>
          <td class="px-5 py-4 text-slate-500"><%= user.email %></td>
          <td class="px-5 py-4 text-slate-500"><%= user.phone_number %></td>
          <td class="px-5 py-4 text-slate-500"><%= user.address %></td>
          <td class="px-5 py-4 text-slate-500"><%= user.role %></td>
          <td class="px-5 py-4 text-slate-500">—</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>