<%= render "template/alert" %>

<div class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6 flex flex-col gap-4 border-b border-gray-200 pb-6 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-indigo-600">Room Management</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-gray-900">Edit Room</h1>
      <p class="mt-2 max-w-2xl text-sm text-gray-500">
        Update room details, availability, photos, and the mapped address shown to users.
      </p>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= link_to "Preview Room", @room, class: "rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-50" %>
      <%= link_to "Back to Rooms", rooms_path, class: "rounded-md bg-gray-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-700" %>
    </div>
  </div>

  <div class="mb-8 grid gap-4 md:grid-cols-4">
    <div class="overflow-hidden rounded-lg border border-gray-200 bg-white md:col-span-2">
      <div class="aspect-[16/9] bg-gray-100">
        <% if @room.image? %>
          <%= cl_image_tag(@room.image_url, class: "h-full w-full object-cover object-center", default_image: "default_image.jpg") %>
        <% else %>
          <%= image_tag("default_image.jpg", class: "h-full w-full object-cover object-center", alt: "Default room image") %>
        <% end %>
      </div>
    </div>

    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium text-gray-500">Room Type</p>
      <p class="mt-2 text-xl font-semibold text-gray-900"><%= @room.roomType.to_s.titleize %></p>
      <p class="mt-4 text-sm font-medium text-gray-500">Address</p>
      <p class="mt-2 text-sm text-gray-700"><%= @room.address.presence || "No address added" %></p>
    </div>

    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium text-gray-500">Current Status</p>
      <div class="mt-3 flex flex-wrap gap-2">
        <span class="inline-flex items-center rounded-md bg-indigo-50 px-2.5 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
          <%= I18n.t("room.room_status.#{@room.room_status}") %>
        </span>
        <% if @room.property.present? %>
          <span class="inline-flex items-center rounded-md bg-purple-50 px-2.5 py-1 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-700/10">Rented</span>
        <% else %>
          <span class="inline-flex items-center rounded-md bg-green-50 px-2.5 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-700/10">Available</span>
        <% end %>
      </div>
      <p class="mt-5 text-sm font-medium text-gray-500">Photos</p>
      <p class="mt-2 text-sm text-gray-700"><%= pluralize(@room.room_images.count + (@room.image? ? 1 : 0), "photo") %></p>
    </div>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-6">
      <h2 class="text-lg font-semibold text-gray-900">Room Details</h2>
      <p class="mt-1 text-sm text-gray-500">Changes are saved when you submit the form at the bottom.</p>
    </div>

    <%= render "form", room: @room %>
  </div>
</div>
