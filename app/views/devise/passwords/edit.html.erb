<%= render "template/login_nav" %>

<section class="relative flex flex-wrap lg:h-screen lg:items-center">
  <div class="w-75 px-4 py-12 sm:px-6 sm:py-16 lg:w-1/2 lg:px-8 lg:py-24">
    <div class="mx-auto max-w-lg text-center">
      <h2 class="text-2xl font-bold sm:text-3xl">Change your password</h2>
      <p class = "mt-4 text-gray-500">Please fill in one of the fields below with your account information. Please Contact Us if you require any assistance.</p>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "mx-auto mb-0 mt-8 max-w-md space-y-4" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div class="field relative">
          <%= f.label :password, "New password" %><br />
          <% if @minimum_password_length %>
            <em>(<%= @minimum_password_length %> characters minimum)</em><br />
          <% end %>
          <%= f.password_field :password, id: "reset_password_password", autofocus: true, autocomplete: "new-password", class: "w-full rounded-lg border-gray-400 p-4 pe-12 text-sm shadow-sm" %>
          <button
            type="button"
            data-password-toggle-button="true"
            data-password-toggle-target="reset_password_password"
            aria-label="Show new password"
            class="absolute inset-y-0 end-0 grid place-content-center px-4 text-gray-400"
          >
            <svg data-password-toggle-eye="true" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            <svg data-password-toggle-eye-off="true" class="hidden h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3l18 18" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.478 10.478a3 3 0 104.243 4.243" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.88 9.88c-1.123 1.123-1.971 2.436-2.558 3.898A9.956 9.956 0 008.5 19.5c4.478 0 8.268-2.943 9.542-7a9.96 9.96 0 00-1.264-2.454" />
            </svg>
          </button>
        </div>

        <div class="field relative">
          <%= f.label :password_confirmation, "Confirm new password" %><br />
          <%= f.password_field :password_confirmation, id: "reset_password_password_confirmation", autocomplete: "new-password", class: "w-full rounded-lg border-gray-400 p-4 pe-12 text-sm shadow-sm" %>
          <button
            type="button"
            data-password-toggle-button="true"
            data-password-toggle-target="reset_password_password_confirmation"
            aria-label="Show password confirmation"
            class="absolute inset-y-0 end-0 grid place-content-center px-4 text-gray-400"
          >
            <svg data-password-toggle-eye="true" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            <svg data-password-toggle-eye-off="true" class="hidden h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3l18 18" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.478 10.478a3 3 0 104.243 4.243" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.88 9.88c-1.123 1.123-1.971 2.436-2.558 3.898A9.956 9.956 0 008.5 19.5c4.478 0 8.268-2.943 9.542-7a9.96 9.96 0 00-1.264-2.454" />
            </svg>
          </button>
        </div>

        <div class="mt-3">
          <%= f.submit "Change my password", class: "inline-block rounded-lg bg-blue-500 px-8 py-3 text-sm font-medium text-white" %>
        </div>
      <% end %>
    </div>
  </div>
   <div class="relative h-64 w-full sm:h-96 lg:h-full lg:w-1/2">
    <img
      alt="Welcome"
      src="https://images.unsplash.com/photo-1630450202872-e0829c9d6172?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=774&q=80"
      class="absolute inset-0 h-full w-full object-cover"
    />
  </div>
</section>      

<%#= render "devise/shared/links" %>
