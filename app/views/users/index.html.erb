<div class="space-y-6">
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-semibold text-slate-900">Users</h1>
        <p class="mt-1 text-sm text-slate-500">Browse all registered users and manage account actions.</p>
      </div>
      <div class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-4 py-2 text-sm font-medium text-slate-700">
        <span class="h-2.5 w-2.5 rounded-full bg-slate-500"></span>
        <%= @users.size %> users
      </div>
    </div>
  </div>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm text-left text-slate-600">
        <thead class="bg-slate-50 text-xs uppercase tracking-[0.2em] text-slate-500">
          <tr>
            <th scope="col" class="px-6 py-4">User</th>
            <th scope="col" class="px-6 py-4">Email</th>
            <th scope="col" class="px-6 py-4">Phone</th>
            <th scope="col" class="px-6 py-4">Address</th>
            <th scope="col" class="px-6 py-4">Role</th>
            <th scope="col" class="px-6 py-4">Rooms</th>
            <th scope="col" class="px-6 py-4">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
          <% @users.each do |user| %>
            <tr class="hover:bg-slate-50">
              <th scope="row" class="whitespace-nowrap px-6 py-4 font-medium text-slate-900"><%= user.user_name %> | <%= user.id %></th>
              <td class="px-6 py-4 text-slate-500"><%= user.email %></td>
              <td class="px-6 py-4 text-slate-500"><%= user.phone_number %></td>
              <td class="px-6 py-4 text-slate-500"><%= user.address %></td>
              <td class="px-6 py-4 text-slate-500"><%= user.role %></td>
              <td class="px-6 py-4 text-slate-500"><%= user.rooms.count %></td>
              <td class="px-6 py-4">
                <div class="flex flex-wrap gap-2">
                  <%= link_to "Show", user_path(user), class: "inline-flex rounded-full bg-slate-100 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-200" %>
                  <%= link_to "Edit", edit_user_path(user), class: "inline-flex rounded-full bg-slate-100 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-200" %>
                  <%= link_to "Delete", user_path(user), method: :delete, data: { confirm: 'Are you sure?' }, class: "inline-flex rounded-full bg-rose-100 px-3 py-1.5 text-xs font-semibold text-rose-700 hover:bg-rose-200" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>